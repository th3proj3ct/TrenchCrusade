<catalogue library="false" id="b923-9554-7b2e-7bd7" name="Iron Sultanate" gameSystemId="sys-6a86-15b3-8ad1-6565" gameSystemRevision="1" revision="1" battleScribeVersion="2.03" type="catalogue" xmlns="http://www.battlescribe.net/schema/catalogueSchema">
  <sharedSelectionEntries>
    <selectionEntry type="upgrade" import="true" name="Alchemist Armour" hidden="false" id="bfe5-cf63-0fd3-d080">
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="f7bb-81a4-7af3-3673" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="5df3-325c-2d3d-d1b1" includeChildSelections="true"/>
      </constraints>
      <profiles>
        <profile name="Alchemist Armour" typeId="86ac-f459-ca64-1e52" typeName="Ability" hidden="false" id="f82d-0d8e-eac4-af0a">
          <characteristics>
            <characteristic name="Description" typeId="896f-6fa6-64e7-5801">Counts as Reinforced Armour and therefore grants a -2 modifier to all injury rolls made against the model wearing it. All attacks with the Keyword FIRE and/or GAS suffer a -1 DICE penalty to injure this model. Additionally, this model does not suffer additional BLOOD MARKERS caused by the Keywords FIRE and/or GAS</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="set" value="true" field="hidden">
          <conditions>
            <condition type="notInstanceOf" value="1" field="selections" scope="ancestor" childId="ee09-9685-c77d-6ecc" shared="true"/>
          </conditions>
        </modifier>
      </modifiers>
      <costs>
        <cost name="Ducats" typeId="2a5e-2001-5d7b-7261" value="50"/>
        <cost name="Glory" typeId="e932-da70-5024-636a" value="0"/>
      </costs>
    </selectionEntry>
