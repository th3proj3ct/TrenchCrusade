    <selectionEntry type="upgrade" import="true" name="Assassin&apos;s Dagger" hidden="false" id="800f-f642-f03a-3c42">
      <constraints>
        <constraint type="max" value="2" field="selections" scope="parent" shared="true" id="33c5-7e75-8dc8-4a8a" includeChildSelections="false"/>
      </constraints>
      <rules>
        <rule name="Assassin&apos;s Dagger" id="92ea-cb7c-87dd-1e01" hidden="false">
          <description>If the Assassin hits an enemy and causes at least one BLOOD MARKER, the Assassin can move away from combat during this Activation. Note that this move does not grant enemies free attacks. Assassins can use both normal and Dash move to do this, though this may not be used for charging.</description>
        </rule>
      </rules>
      <profiles>
        <profile name="Assassin&apos;s Dagger" typeId="e5d0-1216-adf3-422b" typeName="Weapon" hidden="false" id="2c59-6cc1-cec9-c5dc">
          <characteristics>
            <characteristic name="Type" typeId="21a9-9c69-664b-6c8b">1-Handed</characteristic>
            <characteristic name="Range" typeId="c78d-f7dc-aa09-77c9">Melee</characteristic>
            <characteristic name="Modifiers" typeId="03ba-cc34-df47-008a">+1 to Injury</characteristic>
            <characteristic name="Keywords" typeId="fbac-111c-a4aa-d9af">Critical</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Critical" id="4ded-5de0-4b0f-b433" hidden="false" type="rule" targetId="df0f-6ccc-0b39-e88d"/>
