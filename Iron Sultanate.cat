    <selectionEntry type="upgrade" import="true" name="Sapper" hidden="false" id="b61e-1b15-5bc9-9433">
      <entryLinks>
        <entryLink import="true" name="Armour" hidden="false" id="f9f8-3e7e-bdbb-3d1b" type="selectionEntryGroup" targetId="145a-38a7-6913-4272"/>
        <entryLink import="true" name="Equipment" hidden="false" id="1ed1-f311-0305-df21" type="selectionEntryGroup" targetId="3f38-1213-2b65-ab38"/>
        <entryLink import="true" name="Melee Weapon" hidden="false" id="e183-f83f-3c55-bf6a" type="selectionEntryGroup" targetId="3888-9e26-b61f-d51e"/>
        <entryLink import="true" name="Ranged Weapon" hidden="false" id="cf37-5e94-c4c5-98ba" type="selectionEntryGroup" targetId="3197-87b6-917b-bee7"/>
        <entryLink import="true" name="Shovel" hidden="false" id="6846-e4fa-4ea8-9086" type="selectionEntry" targetId="8e87-8281-723e-6def">
          <constraints>
