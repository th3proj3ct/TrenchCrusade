    <selectionEntry type="upgrade" import="true" name="Cloak of Alamut" hidden="false" id="d7da-0972-7099-30bd">
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ce54-08a0-6609-baad" includeChildSelections="false"/>
