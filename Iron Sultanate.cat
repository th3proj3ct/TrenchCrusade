        <categoryLink targetId="5e60-cdbf-60d7-2335" id="307a-3d16-33c3-0b2c" primary="true" name="Troops"/>
      </categoryLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Janissaries" hidden="false" id="bbd9-3775-31c0-56ed">
      <constraints>
        <constraint type="max" value="6" field="selections" scope="force" shared="true" id="e82e-1d3f-02d4-edfa" includeChildSelections="false"/>
      </constraints>
      <costs>
        <cost name="Ducats" typeId="2a5e-2001-5d7b-7261" value="55"/>
        <cost name="Glory" typeId="e932-da70-5024-636a" value="0"/>
      </costs>
      <profiles>
        <profile name="Counter-Charge" typeId="86ac-f459-ca64-1e52" typeName="Ability" hidden="false" id="c7a0-e98d-cc52-4d74">
          <characteristics>
            <characteristic name="Description" typeId="896f-6fa6-64e7-5801">If the first ACTION a Janissary makes during their Activation is a Charge, they can add +1 DICE to their subsequent Melee Attack ACTIONS during this Activation</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <entryLinks>
