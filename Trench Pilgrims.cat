    <selectionEntry type="upgrade" import="true" name="Castigator" hidden="false" id="fd56-e5e5-6357-3636">
      <costs>
        <cost name="Ducats" typeId="2a5e-2001-5d7b-7261" value="50"/>
        <cost name="Glory" typeId="e932-da70-5024-636a" value="0"/>
      </costs>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="2f15-132b-13fe-5de2" includeChildSelections="false"/>
      </constraints>
      <profiles>
        <profile name="Castigator" typeId="bfae-dd5d-e01b-16d0" typeName="Warrior" hidden="false" id="5486-bb4b-cde4-c4f5">
          <characteristics>
            <characteristic name="Movement" typeId="b297-a14b-7cb0-851a">6&quot;</characteristic>
            <characteristic name="Ranged" typeId="b456-0a6a-7b77-edeb">+1 Dice</characteristic>
            <characteristic name="Melee" typeId="b963-f007-690e-2ae5">+1 Dice</characteristic>
            <characteristic name="Armour" typeId="d1ae-d7f2-4c64-1fa9">0</characteristic>
            <characteristic name="Base" typeId="5fab-d798-2d42-57c1">32mm</characteristic>
          </characteristics>
        </profile>
        <profile name="Enforced Orthodoxy" typeId="86ac-f459-ca64-1e52" typeName="Ability" hidden="false" id="53e8-f43f-65d3-b62b">
          <characteristics>
            <characteristic name="Description" typeId="896f-6fa6-64e7-5801">At any point during its Activation, a Castigator may take a RISKY ACTION with +1 DICE. If successful, all friendly models that are Down and within 8” of the Castigator may immediately stand up at no penalty or cost.</characteristic>
          </characteristics>
        </profile>
        <profile name="Whip of God" typeId="86ac-f459-ca64-1e52" typeName="Ability" hidden="false" id="f17e-c22a-6fd7-d056">
          <characteristics>
            <characteristic name="Description" typeId="896f-6fa6-64e7-5801">Unlike other models, a Castigator is allowed to attack friendly models with melee attacks within 1”. They can do this without declaring a charge. Each time the Castigator takes a friendly model Out of Action with a melee attack, set a die aside in a pool as the act of piety inspires the troops. The next time your warband makes a Morale roll, add an amount of +DICE to that roll equal to the amount of dice in the pool and empty it.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <entryLinks>
        <entryLink import="true" name="Armour" hidden="false" id="6353-e2c8-7fe6-e14c" type="selectionEntryGroup" targetId="6a95-e8ed-2fbc-127b" sortIndex="5"/>
        <entryLink import="true" name="Equipment" hidden="false" id="feb0-3fb4-b75e-23c9" type="selectionEntryGroup" targetId="82f1-093c-9bf0-784d" sortIndex="6"/>
        <entryLink import="true" name="Melee Weapons" hidden="false" id="0934-9521-fbea-f68d" type="selectionEntryGroup" targetId="2490-01ed-0dd4-8b6e" sortIndex="3"/>
        <entryLink import="true" name="Ranged Weapons" hidden="false" id="f41d-0886-a14d-b9b8" type="selectionEntryGroup" targetId="ebc6-4a4c-46f1-991d" sortIndex="4"/>
        <entryLink import="true" name="Wrath of God" hidden="false" id="26bd-6343-2586-391d" type="selectionEntry" targetId="7f90-86a5-1979-893e" sortIndex="1"/>
      </entryLinks>
