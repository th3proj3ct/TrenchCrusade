            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="fd1c-1787-c4be-b5a6" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Bonebreaker Mace" hidden="false" id="d1dd-4bd7-0916-f4e3">
          <profiles>
            <profile name="Bonebreaker Mace" typeId="e5d0-1216-adf3-422b" typeName="Weapon" hidden="false" id="31b9-c9db-d698-e71a">
              <characteristics>
                <characteristic name="Type" typeId="21a9-9c69-664b-6c8b">1-Handed</characteristic>
