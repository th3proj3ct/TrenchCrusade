      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Catherine Wheel" hidden="false" id="a7fa-a945-72a7-69bf">
          <profiles>
            <profile name="Catherine Wheel" typeId="e5d0-1216-adf3-422b" typeName="Weapon" hidden="false" id="7515-a031-2448-e1ae">
              <characteristics>
                <characteristic name="Type" typeId="21a9-9c69-664b-6c8b">1-Handed</characteristic>
