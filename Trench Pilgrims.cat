                    <condition type="equalTo" value="1" field="selections" scope="force" childId="b946-d515-a456-1748" shared="true" includeChildSelections="true"/>
                  </conditions>
                </modifierGroup>
              </modifierGroups>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Wrath of God" hidden="false" id="fc55-4df0-3e95-d343">
              <profiles>
                <profile name="Wrath of God" typeId="86ac-f459-ca64-1e52" typeName="Ability" hidden="false" id="3ae3-9cf8-2bad-8f96">
                  <characteristics>
                    <characteristic name="Description" typeId="896f-6fa6-64e7-5801">This is a RISKY ACTION. If successful, roll on the Injury Chart against one enemy model within 3” of the Prophet. Armour offers no protection against this attack</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ca15-adf7-5621-b33a" includeChildSelections="false"/>
              </constraints>
              <modifierGroups>
                <modifierGroup type="and">
                  <modifiers>
                    <modifier type="set" value="0" field="ca15-adf7-5621-b33a"/>
                    <modifier type="set" value="true" field="hidden"/>
                  </modifiers>
                  <conditions>
                    <condition type="equalTo" value="0" field="selections" scope="force" childId="b946-d515-a456-1748" shared="true" includeChildSelections="true"/>
