              </characteristics>
            </profile>
            <profile name="Catherine Wheel" typeId="86ac-f459-ca64-1e52" typeName="Ability" hidden="false" id="7225-4c5e-0a54-574a">
              <characteristics>
                <characteristic name="Description" typeId="896f-6fa6-64e7-5801">The Catherine Wheel rolls on the Injury Chart with 3D6 (instead of usual 2D6), adding all three dice together</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Risky Action" id="0780-421c-5e03-c44d" hidden="false" type="rule" targetId="e4eb-7a5d-f639-29b7"/>
            <infoLink name="Heavy" id="574e-6d26-56b7-8b06" hidden="false" type="rule" targetId="ff49-2fc9-9fd4-0e13"/>
          </infoLinks>
          <constraints>
