          <characteristics>
            <characteristic name="Description" typeId="896f-6fa6-64e7-5801">At the start of each of their Activations, any Stigmatic Nun can remove one BLOOD MARKER (but not an INFECTION MARKER) from themselves and convert it into a BLESSING MARKER.</characteristic>
          </characteristics>
        </profile>
        <profile name="Stigmatic Nun" typeId="bfae-dd5d-e01b-16d0" typeName="Warrior" hidden="false" id="5363-dae4-fee1-da91">
