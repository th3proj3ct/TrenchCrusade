            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3727-1789-0a25-2540" includeChildSelections="false"/>
          </constraints>
        </selectionEntryGroup>
      </selectionEntryGroups>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Trench Pilgrim" hidden="false" id="f209-8841-5fcd-0f56">
      <profiles>
        <profile name="Resurrection" typeId="86ac-f459-ca64-1e52" typeName="Ability" hidden="false" id="1098-f6b7-f220-80d6">
          <characteristics>
            <characteristic name="Description" typeId="896f-6fa6-64e7-5801">When a Trench Pilgrim dies, you may elect to re-buy them after the battle as a Martyr-Penitent resurrected by a Meta-Christ for a cost of 45 ducats. When hit, any attacks against a Martyr-Penitent add -1 DICE when rolling on the Injury Table. Their Melee bonus is increased to +1 DICE (reflected on the profile above). Martyr-Penitents retain any possessions they had before dying and being resurrected</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <selectionEntryGroups>
        <selectionEntryGroup name="Martyr" id="00ec-bbf0-b945-f6f9" hidden="false" defaultSelectionEntryId="10e0-6d67-50e5-751e" sortIndex="7">
          <selectionEntries>
