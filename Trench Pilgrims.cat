                    <characteristic name="Ranged" typeId="b456-0a6a-7b77-edeb">+0 Dice</characteristic>
                    <characteristic name="Melee" typeId="b963-f007-690e-2ae5">+1 Dice</characteristic>
                    <characteristic name="Armour" typeId="d1ae-d7f2-4c64-1fa9">0</characteristic>
