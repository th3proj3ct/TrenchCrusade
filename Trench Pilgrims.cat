            <characteristic name="Ranged" typeId="b456-0a6a-7b77-edeb">N/A</characteristic>
            <characteristic name="Melee" typeId="b963-f007-690e-2ae5">-1 Dice</characteristic>
            <characteristic name="Armour" typeId="d1ae-d7f2-4c64-1fa9">0</characteristic>
            <characteristic name="Base" typeId="5fab-d798-2d42-57c1">25mm</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Martyrdom Device" hidden="false" id="0105-01db-e3ce-18ff" sortIndex="2">
          <profiles>
            <profile name="Martyrdom Device" typeId="86ac-f459-ca64-1e52" typeName="Ability" hidden="false" id="72dc-89e2-669b-6ddf">
              <characteristics>
                <characteristic name="Description" typeId="896f-6fa6-64e7-5801">A Prisoner strapped with a Martyrdom Device can trigger it at any point during their Activation. This does not require an ACTION. When detonated, the explosion is treated as a BLAST 3” weapon targeting the prisoner model. Models within 1” of the prisoner hit by the explosion roll their injuries with +1 DICE. The prisoner rolls 4d6 and adds them together to determine the results of their injury roll. If the explosive goes off and the prisoner somehow survives the battle, you can buy them a new explosive for 35 ducats as normal, or simply field them without. Consumable</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="8a1a-298d-48f4-29d9" includeChildSelections="false"/>
            <constraint type="max" value="4" field="selections" scope="force" shared="true" id="1981-e9d4-2edd-818a" includeChildSelections="false"/>
